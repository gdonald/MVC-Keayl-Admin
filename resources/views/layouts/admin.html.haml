!!! 5
%html{lang: 'en'}
  %head
    %meta{charset: 'utf-8'}
    %meta(name='viewport' content='width=device-width, initial-scale=1')
    %title= $page_title
    != $admin_styles
  %body
    %nav.navbar.navbar-expand-lg.bg-dark.border-bottom.sticky-top.px-3(data-bs-theme='dark')
      .container-fluid
        %button.navbar-toggler.d-lg-none.me-2(type='button' data-bs-toggle='offcanvas' data-bs-target='#admin-sidebar' aria-controls='admin-sidebar' aria-label='Toggle navigation')
          %span.navbar-toggler-icon
        != $admin_brand
        - if $current_admin
          .d-flex.align-items-center.ms-auto
            %span.navbar-text.text-light.me-3 Signed in as #{$current_admin}
            - if $admin_logout_path
              %a.btn.btn-outline-light.btn-sm(href="#{$admin_logout_path}") Log out
    .container-fluid
      .row.flex-nowrap
        %nav#admin-sidebar.offcanvas-lg.offcanvas-start.col-lg-2.bg-body-tertiary.border-end.p-0.min-vh-100(tabindex='-1' aria-labelledby='admin-sidebar-label')
          .offcanvas-header
            %h5#admin-sidebar-label.offcanvas-title= $site_title
            %button.btn-close(type='button' data-bs-dismiss='offcanvas' data-bs-target='#admin-sidebar' aria-label='Close')
          .offcanvas-body.flex-column.align-items-stretch.p-3
            != $admin_menu
        %main#admin-main.col.px-md-4.py-3
          != $admin_breadcrumbs
          - if $flash_notice
            .alert.alert-success(role='alert')= $flash_notice
          %h1.h3.mb-3!= $admin_heading
          != $content
    #admin-confirm-modal.modal.fade(tabindex='-1' aria-labelledby='admin-confirm-label' aria-hidden='true')
      .modal-dialog
        .modal-content
          .modal-header
            %h5#admin-confirm-label.modal-title= $admin_confirm_title
            %button.btn-close(type='button' data-bs-dismiss='modal' aria-label="#{$admin_confirm_cancel}")
          .modal-body
            %p(data-confirm-question)
          .modal-footer
            %button.btn.btn-secondary(type='button' data-bs-dismiss='modal')= $admin_confirm_cancel
            %button.btn.btn-danger(type='button' data-confirm-accept)= $admin_confirm_accept
    != $admin_importmap
    != $admin_scripts
    :javascript
      function adminConfirm(question, onAccept) {
        var modalElement = document.getElementById('admin-confirm-modal');
        modalElement.querySelector('[data-confirm-question]').textContent = question;

        var modal = bootstrap.Modal.getOrCreateInstance(modalElement);
        var acceptButton = modalElement.querySelector('[data-confirm-accept]');

        function cleanup() {
          acceptButton.removeEventListener('click', accept);
          modalElement.removeEventListener('hidden.bs.modal', cleanup);
        }

        function accept() {
          cleanup();
          modal.hide();
          onAccept();
        }

        acceptButton.addEventListener('click', accept);
        modalElement.addEventListener('hidden.bs.modal', cleanup);

        modal.show();
      }

      document.addEventListener('htmx:confirm', function (event) {
        if (!event.detail.question) return;
        event.preventDefault();

        adminConfirm(event.detail.question, function () { event.detail.issueRequest(true); });
      });

      document.addEventListener('submit', function (event) {
        var form = event.target;
        if (!form.matches || !form.matches('[data-confirm]')) return;
        if (form.dataset.confirmed === 'yes') return;
        event.preventDefault();

        adminConfirm(form.getAttribute('data-confirm'), function () {
          form.dataset.confirmed = 'yes';
          form.submit();
        });
      });

      document.addEventListener('change', function (event) {
        var target = event.target;
        if (!target.matches) return;
        var form = target.closest('form');
        if (!form) return;
        if (target.matches('[data-batch-all]')) {
          form.querySelectorAll('[data-batch-select]').forEach(function (box) { box.checked = target.checked; });
        }
        if (target.matches('[data-batch-select], [data-batch-all]')) {
          var count = form.querySelectorAll('[data-batch-select]:checked').length;
          form.querySelectorAll('[data-batch-count]').forEach(function (el) { el.textContent = count; });
        }
      });
